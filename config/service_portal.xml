  display: block;
}
.contact-box {
  background: #e7f3ff;
  padding: 20px;
  border-radius: 4px;
  margin-top: 30px;
}
</style>

<script>
document.querySelectorAll('.accordion-header').forEach(header => {
  header.addEventListener('click', function() {
    this.closest('.accordion-item').classList.toggle('active');
  });
});
</script>
    ]]></template>
  </service_portal_widget>

</export_set>
