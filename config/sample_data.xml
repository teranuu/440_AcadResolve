  <!-- SAMPLE DATA: Notifications Template -->
  <notification_templates>
    <template name="welcome_email">
      <subject>Welcome to Academic Resolve</subject>
      <body>
Hello,

Welcome to the Academic Resolve system. If you have any questions about reporting or resolving book disputes, please visit our Help & FAQ section or contact the library.

Best regards,
Academic Library Team
      </body>
    </template>

    <template name="reminder_email">
      <subject>Pending Action Required - Book Dispute #${incident.number}</subject>
      <body>
Hello,

This is a reminder that you have a pending action on incident #${incident.number}.

Book: ${incident.book_title}
Status: ${incident.state}
Amount: $${incident.calculated_fee}

Please complete your action within the next 24 hours.

View Incident: ${incident.url}

Best regards,
Academic Library Team
      </body>
    </template>
  </notification_templates>

