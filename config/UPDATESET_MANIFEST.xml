<?xml version="1.0" encoding="UTF-8"?>
<update_set name="x_1997678_acad_resolve_updateset_v1" version="1.0.0">
    <metadata>
        <application>Academic Resolve - Book Dispute Resolution System</application>
        <description>Lost/Damaged Book Dispute & Settlement Application for Educational Institutions</description>
        <organization>Zurich Edition</organization>
        <version>1.0.0</version>
        <author>Academic Resolve Development Team</author>
        <created_date>2026-04-19</created_date>
        <scope>x-1997678-acad-resolve</scope>
        <scope_id>x_1997678_acadreso</scope_id>
    </metadata>

    <components>
        <!-- Database Tables -->
        <component type="table" name="x_1997678_acad_resolve_book_incident">
            <file>config/database_schema.xml</file>
            <description>Main incident table for book disputes</description>
            <requires_restart>false</requires_restart>
        </component>

        <component type="table" name="x_1997678_acad_resolve_fee_schedule">
            <file>config/database_schema.xml</file>
            <description>Fee calculation reference table</description>
            <requires_restart>false</requires_restart>
        </component>

        <component type="table" name="x_1997678_acad_resolve_approval">
            <file>config/database_schema.xml</file>
            <description>Approval workflow tracking table</description>
            <requires_restart>false</requires_restart>
        </component>

        <!-- Business Rules (5) -->
        <component type="business_rule" name="Auto Calculate Fee">
            <file>config/business_rules.xml</file>
            <description>Automatically calculates incident fee</description>
            <execution_order>100</execution_order>
            <active>true</active>
        </component>

        <component type="business_rule" name="Notify Library on Incident">
            <file>config/business_rules.xml</file>
            <description>Sends notification to library staff</description>
            <execution_order>200</execution_order>
            <active>true</active>
        </component>

        <component type="business_rule" name="Close Incident on Payment">
            <file>config/business_rules.xml</file>
            <description>Closes incident when payment recorded</description>
            <execution_order>150</execution_order>
            <active>true</active>
        </component>

        <component type="business_rule" name="Validate Incident Data">
            <file>config/business_rules.xml</file>
            <description>Validates required fields</description>
            <execution_order>50</execution_order>
            <active>true</active>
        </component>

        <component type="business_rule" name="Set Priority by Damage">
            <file>config/business_rules.xml</file>
            <description>Sets priority based on damage level</description>
            <execution_order>75</execution_order>
            <active>true</active>
        </component>

        <!-- Client Scripts (5) -->
        <component type="client_script" name="Validate Incident Form" script_type="onSubmit" active="true"/>
        <component type="client_script" name="Calculate Fee Preview" script_type="onChange" active="true"/>
        <component type="client_script" name="Show/Hide Fields Based on Type" script_type="onChange" active="true"/>
        <component type="client_script" name="Check User Permissions" script_type="onLoad" active="true"/>
        <component type="client_script" name="Handle Photo Upload" script_type="onLoad" active="true"/>

        <!-- UI Actions (2+) -->
        <component type="ui_action" name="Create Payment Request" active="true"/>
        <component type="ui_action" name="Approve Replacement" active="true"/>

        <!-- Notifications (4+) -->
        <component type="notification" name="Incident Created" active="true"/>
        <component type="notification" name="Incident Confirmation" active="true"/>
        <component type="notification" name="Approval Requested" active="true"/>
        <component type="notification" name="Dispute Approved" active="true"/>

        <!-- Integration Hub (4) -->
        <component type="integration_hub" name="Payment Gateway Connector" type="outbound" active="true"/>
        <component type="integration_hub" name="SMTP Email Service" type="outbound" active="true"/>
        <component type="integration_hub" name="Copilot AI Assessment" type="outbound" active="true"/>
        <component type="integration_hub" name="LMS Student Verification" type="outbound" active="true"/>

        <!-- Flows (4) -->
        <component type="flow" name="Incident Intake Flow" active="true"/>
        <component type="flow" name="Incident Approval Workflow" active="true"/>
        <component type="flow" name="Payment Processing Flow" active="true"/>
        <component type="flow" name="Incident Escalation Flow" active="true"/>

        <!-- Service Portal -->
        <component type="service_portal_widget" name="Report Book Incident" active="true"/>

        <!-- User Roles (4) -->
        <component type="user_role" name="acad_resolve.admin" active="true"/>
        <component type="user_role" name="acad_resolve.library_staff" active="true"/>
        <component type="user_role" name="acad_resolve.student" active="true"/>
        <component type="user_role" name="acad_resolve.approver" active="true"/>

        <!-- Sample Data -->
        <component type="sample_data" name="Fee Schedule Data" optional="false"/>
    </components>

    <dependencies>
        <required_plugins>
            <plugin>com.snc.integration_hub</plugin>
            <plugin>com.snc.flow_designer</plugin>
            <plugin>com.snc.service_portal</plugin>
        </required_plugins>
    </dependencies>

</update_set>